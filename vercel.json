{
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/auth/invite/:token", "destination": "/auth/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(js|css|png|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}